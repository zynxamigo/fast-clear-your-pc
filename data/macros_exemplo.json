[
  {
    "id": "spotify_next",
    "name": "Spotify - Próxima música",
    "trigger": "hotkey",
    "trigger_params": {"hotkey": "ctrl+alt+right"},
    "actions": [{"action_type": "spotify_next", "params": {}}],
    "enabled": true
  },
  {
    "id": "spotify_prev",
    "name": "Spotify - Música anterior",
    "trigger": "hotkey",
    "trigger_params": {"hotkey": "ctrl+alt+left"},
    "actions": [{"action_type": "spotify_previous", "params": {}}],
    "enabled": true
  },
  {
    "id": "spotify_play",
    "name": "Spotify - Play/Pause",
    "trigger": "hotkey",
    "trigger_params": {"hotkey": "ctrl+alt+space"},
    "actions": [{"action_type": "spotify_play_pause", "params": {}}],
    "enabled": true
  },
  {
    "id": "spotify_open",
    "name": "Spotify - Abrir app",
    "trigger": "hotkey",
    "trigger_params": {"hotkey": "ctrl+alt+s"},
    "actions": [{"action_type": "spotify_open", "params": {"path": ""}}],
    "enabled": true
  },
  {
    "id": "notepad_som",
    "name": "Abrir Bloco de Notas com som",
    "trigger": "manual",
    "actions": [
      {
        "action_type": "open_app_with_sound",
        "params": {
          "path": "notepad.exe",
          "sound_path": "C:\\Windows\\Media\\Windows Notify.wav",
          "mode": "sound_first",
          "delay_ms": "200"
        }
      }
    ],
    "enabled": true
  }
]